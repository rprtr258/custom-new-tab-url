{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "types": ["chrome"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "js"]
}